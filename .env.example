# Copy this file to `.env` and fill in the real values, then restart the dev
# server with `npx expo start -c` (the -c clears the cache so env changes load).
#
# Values live in the Supabase dashboard:
#   URL: Project Settings -> Data API -> Project URL (WITHOUT the /rest/v1/ suffix)
#   KEY: Project Settings -> API Keys -> the "publishable" (or legacy anon) key
#
# The publishable key is designed to ship in client apps — Row Level Security
# is what protects the data. The service_role / secret key must NEVER be used
# here or anywhere in this repo.
#
# EXPO_PUBLIC_ vars are embedded into the app bundle at build time; they are
# readable by anyone with the app binary. That's fine for these two values and
# not fine for anything secret.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_...

# PowerSync instance URL (Stage 3 offline sync). From the PowerSync
# dashboard after creating an instance — looks like
# https://<id>.powersync.journeyapps.com. Leave unset to stay in
# online-only mode (Expo Go always stays online-only regardless).
# EXPO_PUBLIC_POWERSYNC_URL=https://YOUR-INSTANCE.powersync.journeyapps.com
